# MySQL connection (required)
MYSQL_USER=myuser
MYSQL_PASSWORD=secret

# Optional
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=mydb
MYSQL_POOL_SIZE=5

# Allow INSERT/UPDATE/DELETE (default: false). UPDATE/DELETE require WHERE.
MYSQL_ALLOW_WRITE=false

# TLS/SSL (recommended for staging/prod)
MYSQL_SSL_ENABLED=false
# Set true to validate server certificate chain (recommended)
MYSQL_SSL_VERIFY_CERT=true
# Optional CA bundle path to validate the server certificate
MYSQL_SSL_CA=
# Optional client certificate pair (if MySQL requires mTLS)
MYSQL_SSL_CERT=
MYSQL_SSL_KEY=
